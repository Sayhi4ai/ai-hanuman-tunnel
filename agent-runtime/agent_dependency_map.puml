@startuml

package "Core Runtime" {
  class task_queue
  class load_balancer
  class graph
  class vector_memory
  class messaging
}

package "Core Agents" {
  class planner
  class writer
  class reasoner
}

package "Swarm + Evolution" {
  class swarm_agent
  class genetic_agent
  class evolution_engine
  class swarm_manager
}

package "Governance + Safety" {
  class governance_agent
  class ethics_agent
  class threat_agent
  class security_agent
  class policy_engine
  class threat_detector
  class security_scanner
}

package "Distributed + Mesh" {
  class distributed_agent
  class mesh_agent
  class mesh_network
  class cluster_manager
  class cluster_node
}

package "Federation + Diplomacy" {
  class federation_agent
  class federation_manager
  class diplomacy_agent
  class diplomacy_engine
}

task_queue --> load_balancer
load_balancer --> graph
load_balancer --> planner
load_balancer --> writer
load_balancer --> reasoner

planner --> swarm_agent
reasoner --> swarm_agent
swarm_agent --> genetic_agent

planner --> governance_agent
writer --> governance_agent
reasoner --> governance_agent

governance_agent --> ethics_agent
governance_agent --> threat_agent
threat_agent --> security_agent

planner --> distributed_agent
writer --> distributed_agent
reasoner --> distributed_agent

distributed_agent --> mesh_agent
mesh_agent --> federation_agent
federation_agent --> diplomacy_agent

vector_memory --> planner
vector_memory --> writer
vector_memory --> reasoner

@enduml
